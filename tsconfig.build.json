{
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "customConditions": ["mark"],
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmitOnError": true,
    "outDir": "dist",
    "rewriteRelativeImportExtensions": true,
    "rootDir": "src",
    "sourceMap": false,
    "target": "es2024"
  },
  "exclude": ["**/__mocks__/**", "**/__tests__/**"],
  "extends": "./tsconfig.json",
  "files": [
    "typings/@flex-development/mark/ast/index.d.mts",
    "typings/@flex-development/mark/compile/index.d.mts",
    "typings/@flex-development/mark/parse/index.d.mts"
  ],
  "include": ["dist/**/*", "src/**/**.mts"]
}
